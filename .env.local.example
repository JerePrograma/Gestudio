# Development only. Default Spring profile.
SPRING_PROFILES_ACTIVE=dev
# Development only. Local PostgreSQL JDBC URL.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/gestudio_db
# Development only. Local database user.
SPRING_DATASOURCE_USERNAME=postgres
# Development only. Deliberately obvious local password; replace if your local DB differs.
SPRING_DATASOURCE_PASSWORD=local-only-change-me
# Development only. Validate the Flyway-managed schema.
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
# Development only. Keep Flyway enabled for a representative local schema.
SPRING_FLYWAY_ENABLED=true
# Development only. Keep false for new databases.
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false
# Development only. Used only when baseline-on-migrate is explicitly enabled.
SPRING_FLYWAY_BASELINE_VERSION=1

# Development only. Not a production secret; replace before sharing an environment.
JWT_SECRET=local-only-jwt-secret-change-before-sharing
# Development only. Distinguishes local tokens from production tokens.
JWT_ISSUER=gestudio-local
# Development only. Access-token lifetime in hours.
JWT_ACCESS_TOKEN_HOURS=2
# Development only. Refresh-token lifetime in hours.
JWT_REFRESH_TOKEN_HOURS=168

# Development only. Mail uses the no-op implementation; these may remain empty.
SPRING_MAIL_HOST=
# Development only. Mail uses the no-op implementation; these may remain empty.
SPRING_MAIL_PORT=587
# Development only. Mail uses the no-op implementation; these may remain empty.
SPRING_MAIL_USERNAME=
# Development only. Mail uses the no-op implementation; these may remain empty.
SPRING_MAIL_PASSWORD=
# Development only. Mail uses the no-op implementation; these may remain empty.
SPRING_MAIL_IMAP_HOST=
# Development only. Mail uses the no-op implementation; these may remain empty.
SPRING_MAIL_IMAP_PORT=993
# Development only. Mail uses the no-op implementation; these may remain empty.
SPRING_MAIL_IMAP_USERNAME=
# Development only. Mail uses the no-op implementation; these may remain empty.
SPRING_MAIL_IMAP_PASSWORD=
# Development only. Mail uses the no-op implementation; these may remain empty.
SPRING_MAIL_IMAP_SENT_FOLDER=INBOX.Sent

# Development only. IANA business time zone.
APP_TIME_ZONE=America/Argentina/Buenos_Aires
# Development only. Relative to backend/ when Maven starts the app.
APP_RECEIPTS_PATH=../pdfs
# Development only. Comma-separated browser origins.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081
# Development only. Off by default to avoid mutating local data unexpectedly.
APP_SCHEDULING_ENABLED=false
# Development only. One-shot bootstrap; keep false except during explicit initial provisioning.
APP_BOOTSTRAP_SUPERADMIN_ENABLED=false
# Development only. Required only while the SUPERADMIN bootstrap is enabled.
APP_BOOTSTRAP_SUPERADMIN_USERNAME=
# Development only. Supply externally; never commit a real password.
APP_BOOTSTRAP_SUPERADMIN_PASSWORD=
# Development only. Explicit recovery for an existing ADMINISTRADOR password.
APP_BOOTSTRAP_ADMIN_RESET_EXISTING_PASSWORD=false
APP_BOOTSTRAP_ADMIN_USERNAME=
APP_BOOTSTRAP_ADMIN_PASSWORD=
# Development only. Repository root used by the legacy asset resolver.
GESTUDIO_HOME=..
# Development only. Backend HTTP port.
SERVER_PORT=8080
# Development only. Root log level.
LOGGING_LEVEL_ROOT=INFO

# Development only. Vite API URL.
VITE_API_BASE_URL=http://localhost:8080/api
# Development only. Vite display time zone.
VITE_APP_TIME_ZONE=America/Argentina/Buenos_Aires

# Development only. Compose database name.
POSTGRES_DB=gestudio_db
# Development only. Compose database user.
POSTGRES_USER=postgres
# Development only. Deliberately obvious Compose password.
POSTGRES_PASSWORD=local-only-change-me
# Development only. Change when 5432 is already occupied.
POSTGRES_PORT=5432
# Development only. Change when 8080 is already occupied.
BACKEND_PORT=8080
# Development only. Change when 8081 is already occupied.
FRONTEND_PORT=8081
# Development only. Uncomment only when an explicit unique project name is needed.
# COMPOSE_PROJECT_NAME=gestudio-my-worktree
# Development only. Local backend image name.
BACKEND_IMAGE=gestudio-backend:local
# Development only. Local frontend image name.
FRONTEND_IMAGE=gestudio-frontend:local
