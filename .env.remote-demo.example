# Copy this file to .env.remote-demo and replace every placeholder value.
# .env.remote-demo is intentionally ignored and must never be committed.

SPRING_PROFILES_ACTIVE=remote-demo
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false
SPRING_FLYWAY_BASELINE_VERSION=1

POSTGRES_DB=gestudio_remote_demo
POSTGRES_USER=gestudio_remote_demo
POSTGRES_PASSWORD=REPLACE_WITH_RANDOM_POSTGRES_PASSWORD

JWT_SECRET=REPLACE_WITH_RANDOM_JWT_SECRET_AT_LEAST_32_BYTES
JWT_ISSUER=gestudio-remote-demo
JWT_AUDIENCE=gestudio-web
JWT_ACCESS_TOKEN_TTL=PT15M
JWT_REFRESH_TOKEN_TTL=P1D

APP_TIME_ZONE=America/Argentina/Buenos_Aires
APP_RECEIPTS_PATH=/app/data/receipts
APP_CORS_ALLOWED_ORIGINS=https://REPLACE_WITH_FRONTEND_HOST
APP_REMOTE_DEMO_PROXY_TOKEN=REPLACE_WITH_INDEPENDENT_RANDOM_PAGES_PROXY_TOKEN_AT_LEAST_32_BYTES
APP_SCHEDULING_ENABLED=false
APP_OBSERVABILITY_METRICS_TOKEN=REPLACE_WITH_INDEPENDENT_RANDOM_METRICS_TOKEN_AT_LEAST_32_BYTES
APP_SECURITY_BCRYPT_STRENGTH=12
APP_SECURITY_REFRESH_COOKIE_NAME=gestudio_remote_demo_refresh
APP_SECURITY_REFRESH_COOKIE_SECURE=true
APP_SECURITY_REFRESH_COOKIE_SAME_SITE=Strict
APP_SECURITY_REFRESH_COOKIE_DOMAIN=
APP_SECURITY_REFRESH_COOKIE_PATH=/api/login
APP_BOOTSTRAP_SUPERADMIN_ENABLED=false
APP_LOCAL_ADMIN_PASSWORD_RESET_ENABLED=false
APP_JERE_PLATFORM_STUDENT_EXPORT_ENABLED=false

SERVER_PORT=8080
BACKEND_PORT=18080
BACKEND_IMAGE=gestudio-backend:remote-demo
COMPOSE_PROJECT_NAME=gestudio-remote-demo
LOGGING_LEVEL_ROOT=INFO
